{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the widget window",
  "windows": ["widget"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:app:allow-app-hide",
    "core:window:allow-close",
    "autostart:default"
  ]
}
